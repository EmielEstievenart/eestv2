{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Tests: all",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/unit_tests.exe",
            "args": [],
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "variadic_templates",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/variadic_templates.exe",
            "args": [],
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Tests: allLDAB",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/unit_tests.exe",
            "args": [],
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Test: TCP Server Lifecycle ",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/unit_tests.exe",
            "args": [
                "--gtest_filter=TcpServerLifeCycleTest.*"
            ],
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Test: Single TCP Server ",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/unit_tests.exe",
            "args": [
                "--gtest_filter=TcpConnectionTest.ClientToServerDataTransfer"
            ],
            "stopAtEntry": true,
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Test: StartSendingAndDestruct",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/unit_tests.exe",
            "args": [
                "--gtest_filter=TcpConnectionLifeCycleTests.StartSendingAndDestruct"
            ],
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Attach to Process",
            "type": "cppvsdbg",
            "request": "attach",
            "processId": "${command:pickProcess}"
        },
        {
            "name": "Example: Templates",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/templates_example.exe",
            "args": [],
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Example: SFINAE ",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/sfinae.exe",
            "args": [],
            "cwd": "${command:cmake.buildDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Example: FTXUI Text View",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.buildDirectory}/bin/ftxui_text_view_example.exe",
            "args": [],
            "cwd": "${command:cmake.buildDirectory}",
            "externalConsole": true,
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Debug CMake Target",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": [],
            "cwd": "${command:cmake.launchTargetDirectory}",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "Test selected",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${cmake.testProgram}",
            "args": [
                "${cmake.testArgs}"
            ],
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "neverOpen"
        }
    ]
}
