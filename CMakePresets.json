{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "cacheVariables": {
        "BOOST_ROOT": "$penv{BOOST_ROOT}",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "FTXUI_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "linux-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
      "name": "linux-gcc-debug",
      "displayName": "Linux GCC Debug",
      "description": "Linux - GCC - Ninja - x64 - Debug",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Linux GCC Release",
      "description": "Linux - GCC - Ninja - x64 - Release",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "linux-gcc-tsan",
      "displayName": "Linux GCC ThreadSanitizer",
      "description": "Linux - GCC - Ninja - x64 - Debug with ThreadSanitizer",
      "inherits": "linux-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-fsanitize=thread -g -O1",
        "CMAKE_C_FLAGS": "-fsanitize=thread -g -O1",
        "CMAKE_EXE_LINKER_FLAGS": "-fsanitize=thread",
        "CMAKE_SHARED_LINKER_FLAGS": "-fsanitize=thread",
        "ENABLE_CTEST": "OFF"
      }
    },
    {
      "name": "windows-base",
      "hidden": true,
      "inherits": "base",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "windows-msvc-base",
      "hidden": true,
      "inherits": "windows-base",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "Visual Studio"
        }
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Windows MSVC Debug",
      "description": "Windows - MSVC - Visual Studio 2022 - x64 - Debug",
      "inherits": "windows-msvc-base",
      "cacheVariables": {}
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Windows MSVC Release",
      "description": "Windows - MSVC - Visual Studio 2022 - x64 - Release",
      "inherits": "windows-msvc-base",
      "cacheVariables": {}
    },
    {
      "name": "windows-clang-base",
      "hidden": true,
      "inherits": "windows-base",
      "generator": "Ninja",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_C_COMPILER": "C:/Program Files/LLVM/bin/clang.exe",
        "CMAKE_CXX_COMPILER": "C:/Program Files/LLVM/bin/clang++.exe"
      },
      "vendor": {
        "jetbrains.com/clion": {
          "toolchain": "Clang"
        }
      }
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Windows Clang Debug",
      "description": "Windows - Clang - Ninja - x64 - Debug",
      "inherits": "windows-clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS": "-g -gdwarf-4"
      }
    },
    {
      "name": "windows-clang-release",
      "displayName": "Windows Clang Release",
      "description": "Windows - Clang - Ninja - x64 - Release",
      "inherits": "windows-clang-base",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-gcc-debug",
      "displayName": "Build Linux GCC Debug",
      "configurePreset": "linux-gcc-debug",
      "jobs": 0
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Build Linux GCC Release",
      "configurePreset": "linux-gcc-release",
      "jobs": 0
    },
    {
      "name": "linux-gcc-tsan",
      "displayName": "Build Linux GCC ThreadSanitizer",
      "configurePreset": "linux-gcc-tsan",
      "jobs": 0
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Build Windows MSVC Debug",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug",
      "jobs": 0
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Build Windows MSVC Release",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release",
      "jobs": 0
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Build Windows Clang Debug",
      "configurePreset": "windows-clang-debug",
      "jobs": 0
    },
    {
      "name": "windows-clang-release",
      "displayName": "Build Windows Clang Release",
      "configurePreset": "windows-clang-release",
      "jobs": 0
    }
  ],
  "testPresets": [
    {
      "name": "linux-gcc-debug",
      "displayName": "Test Linux GCC Debug",
      "configurePreset": "linux-gcc-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Test Linux GCC Release",
      "configurePreset": "linux-gcc-release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Test Windows MSVC Debug",
      "configurePreset": "windows-msvc-debug",
      "configuration": "Debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Test Windows MSVC Release",
      "configurePreset": "windows-msvc-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Test Windows Clang Debug",
      "configurePreset": "windows-clang-debug",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "windows-clang-release",
      "displayName": "Test Windows Clang Release",
      "configurePreset": "windows-clang-release",
      "output": {
        "outputOnFailure": true
      }
    }
  ],
  "workflowPresets": [
    {
      "name": "linux-gcc-debug",
      "displayName": "Workflow Linux GCC Debug",
      "steps": [
        {
          "type": "configure",
          "name": "linux-gcc-debug"
        },
        {
          "type": "build",
          "name": "linux-gcc-debug"
        },
        {
          "type": "test",
          "name": "linux-gcc-debug"
        }
      ]
    },
    {
      "name": "linux-gcc-release",
      "displayName": "Workflow Linux GCC Release",
      "steps": [
        {
          "type": "configure",
          "name": "linux-gcc-release"
        },
        {
          "type": "build",
          "name": "linux-gcc-release"
        },
        {
          "type": "test",
          "name": "linux-gcc-release"
        }
      ]
    },
    {
      "name": "windows-msvc-debug",
      "displayName": "Workflow Windows MSVC Debug",
      "steps": [
        {
          "type": "configure",
          "name": "windows-msvc-debug"
        },
        {
          "type": "build",
          "name": "windows-msvc-debug"
        },
        {
          "type": "test",
          "name": "windows-msvc-debug"
        }
      ]
    },
    {
      "name": "windows-msvc-release",
      "displayName": "Workflow Windows MSVC Release",
      "steps": [
        {
          "type": "configure",
          "name": "windows-msvc-release"
        },
        {
          "type": "build",
          "name": "windows-msvc-release"
        },
        {
          "type": "test",
          "name": "windows-msvc-release"
        }
      ]
    },
    {
      "name": "windows-clang-debug",
      "displayName": "Workflow Windows Clang Debug",
      "steps": [
        {
          "type": "configure",
          "name": "windows-clang-debug"
        },
        {
          "type": "build",
          "name": "windows-clang-debug"
        },
        {
          "type": "test",
          "name": "windows-clang-debug"
        }
      ]
    },
    {
      "name": "windows-clang-release",
      "displayName": "Workflow Windows Clang Release",
      "steps": [
        {
          "type": "configure",
          "name": "windows-clang-release"
        },
        {
          "type": "build",
          "name": "windows-clang-release"
        },
        {
          "type": "test",
          "name": "windows-clang-release"
        }
      ]
    }
  ]
}
